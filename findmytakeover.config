    credentials: default
    # Optional when credentials is "default" — omit to auto-discover from CLI, or list specific projects
    # accounts:
    #   - project0
    #   - project1

  azure:
    enabled: false
    # Use "default" to use local Azure CLI credentials (auto-discovers all enabled subscriptions),
    # or specify a mapping with AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET
    credentials: default
    # Optional when credentials is "default" — omit to auto-discover from CLI, or list specific subscriptions
    # accounts:
    #   - subscription1
    #   - subscription2

  cloudflare:
    enabled: false
    # Use "default" to read the CLOUDFLARE_API_TOKEN env var (auto-discovers all accessible accounts),
    # or specify a scoped API token string
    credentials: default
    # Optional when credentials is "default" — omit to auto-discover, or list specific account IDs
    # accounts:
    #   - 0123456789abcdef0123456789abcdef

  oracle:
    enabled: false
    # Use "default" to use ~/.oci/config (DEFAULT profile; auto-discovers tenancy + compartments),
    # or specify a path to an OCI config file
    credentials: default
    # Optional when credentials is "default" — omit to auto-discover, or list specific compartment OCIDs
    # accounts:
    #   - ocid1.compartment.oc1..aaaa
