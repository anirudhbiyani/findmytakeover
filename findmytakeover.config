exclude:
  ipaddress:
    - 100.1.0.0/16
  domains:
    - google.com 
    - example.com

dns:
  aws:
    enabled: false/true
    # Use "default" to use local AWS CLI credentials (auto-discovers account from caller identity),
    # or specify an IAM role name to assume
    credentials: default
    # Optional when credentials is "default" — omit to auto-discover from CLI, or list specific accounts
    # accounts:
    #   - 123456789012
    #   - 098765432109

  gcp:
    enabled: true/false
    # Use "default" to use Application Default Credentials (auto-discovers all accessible projects),
    # or specify a path to a service account JSON key file
    credentials: default
    # Optional when credentials is "default" — omit to auto-discover from CLI, or list specific projects
    # accounts:
    #   - project0
    #   - project1

  azure:
    enabled: false/true
    # Use "default" to use local Azure CLI credentials (auto-discovers all enabled subscriptions),
    # or specify a mapping with AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET
    credentials: default
    # Optional when credentials is "default" — omit to auto-discover from CLI, or list specific subscriptions
    # accounts:
    #   - subscription1
    #   - subscription2

infra:
  aws:
    enabled: false/true
    # Use "default" to use local AWS CLI credentials (auto-discovers account from caller identity),
    # or specify an IAM role name to assume
    credentials: default
    # Optional when credentials is "default" — omit to auto-discover from CLI, or list specific accounts
    # accounts:
    #   - 123456789012
    #   - 098765432109

  gcp:
    enabled: true/false
    # Use "default" to use Application Default Credentials (auto-discovers all accessible projects),
    # or specify a path to a service account JSON key file
    credentials: default
    # Optional when credentials is "default" — omit to auto-discover from CLI, or list specific projects
    # accounts:
    #   - project0
    #   - project1

  azure:
    enabled: false/true
    # Use "default" to use local Azure CLI credentials (auto-discovers all enabled subscriptions),
    # or specify a mapping with AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET
    credentials: default
    # Optional when credentials is "default" — omit to auto-discover from CLI, or list specific subscriptions
    # accounts:
    #   - subscription1
    #   - subscription2